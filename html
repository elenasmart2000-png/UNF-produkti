<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Елена Уткина — Финансовый директор для производства продуктов питания</title>
  <style>
    :root{
      --bg:#f5f7f4;
      --paper:#ffffff;
      --ink:#172033;
      --muted:#5e6a70;
      --soft:#eef4ed;
      --soft2:#f7faf6;
      --line:#dce6dc;
      --green:#244f37;
      --green2:#3f7a54;
      --gold:#b28a3a;
      --red:#a24a3a;
      --shadow:0 18px 55px rgba(23,32,51,.09);
      --radius:22px;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:Inter, Arial, Helvetica, sans-serif;
      color:var(--ink);
      background:linear-gradient(180deg,#fbfcfb 0%,var(--bg) 100%);
      line-height:1.55;
    }
    a{color:var(--green);text-decoration:none}
    a:hover{text-decoration:underline}
    .page{width:min(1120px,calc(100% - 32px));margin:28px auto 52px;background:var(--paper);border:1px solid var(--line);border-radius:30px;box-shadow:var(--shadow);overflow:hidden}
    .topbar{height:8px;background:linear-gradient(90deg,var(--green),var(--green2),var(--gold))}
    header{padding:46px 48px 34px;background:linear-gradient(135deg,#ffffff 0%,#f8fbf7 72%,#edf5ed 100%);border-bottom:1px solid var(--line)}
    .kicker{font-size:13px;letter-spacing:.13em;text-transform:uppercase;color:var(--gold);font-weight:850;margin-bottom:12px}
    h1{margin:0 0 12px;font-size:54px;line-height:1;font-weight:850;letter-spacing:-.045em;color:var(--ink)}
    .position{font-size:22px;line-height:1.35;color:var(--green);font-weight:850;letter-spacing:-.015em;margin:0 0 18px;max-width:900px}
    .subtitle{font-size:18px;max-width:960px;color:#344258;margin:0 0 22px}
    .contacts{display:flex;gap:12px;flex-wrap:wrap;margin-top:20px}
    .contact{padding:10px 14px;background:#fff;border:1px solid var(--line);border-radius:999px;color:var(--muted);font-size:14px;font-weight:650}
    main{padding:0 48px 48px}
    section{padding:38px 0;border-bottom:1px solid var(--line)}
    section:last-child{border-bottom:none;padding-bottom:0}
    .section-head{display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:22px}
    .label{font-size:12px;text-transform:uppercase;letter-spacing:.13em;color:var(--gold);font-weight:850;margin-bottom:6px}
    h2{margin:0;font-size:30px;line-height:1.15;letter-spacing:-.03em;color:var(--ink)}
    h3{margin:0 0 12px;font-size:20px;color:var(--green);letter-spacing:-.015em}
    p{margin:0 0 14px;color:var(--muted)}
    .lead{font-size:18px;color:#344258;max-width:980px}
    .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:18px}
    .grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
    .card{background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:22px;box-shadow:0 10px 25px rgba(23,32,51,.045)}
    .accent-card{background:linear-gradient(180deg,#ffffff 0%,#f8fbf7 100%);border-top:4px solid var(--green)}
    .result-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
    .result{background:var(--soft);border:1px solid #dfeadf;border-radius:18px;padding:18px;min-height:138px}
    .result strong{display:block;font-size:27px;line-height:1.05;color:var(--green);letter-spacing:-.035em;margin-bottom:9px}
    .result span{display:block;font-size:14px;color:#46536a;font-weight:650}
    ul{margin:0;padding-left:20px;color:var(--muted)}
    li{margin:8px 0}
    .owner-list{columns:2;column-gap:44px}
    .owner-list li{break-inside:avoid}
    .steps{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
    .step{background:#fff;border:1px solid var(--line);border-radius:18px;padding:18px;position:relative;overflow:hidden}
    .step:before{content:attr(data-num);position:absolute;right:14px;top:8px;font-size:42px;color:#e5eee5;font-weight:900;line-height:1}
    .step h3{font-size:18px;margin-bottom:8px;position:relative;z-index:1}
    .step p{position:relative;z-index:1}
    .tags{display:flex;flex-wrap:wrap;gap:10px}
    .tag{padding:9px 12px;border-radius:999px;background:#fff;border:1px solid var(--line);font-size:14px;color:#344258;font-weight:650}
    .tag.hot{background:#f8f0df;border-color:#ead7aa;color:#674d1c}
    .company{border:1px solid var(--line);border-radius:var(--radius);padding:26px;background:#fff;box-shadow:0 10px 25px rgba(23,32,51,.045);margin-top:18px}
    .company:first-of-type{margin-top:0}
    .company-top{display:flex;justify-content:space-between;gap:20px;align-items:flex-start;margin-bottom:14px;border-bottom:1px solid var(--line);padding-bottom:14px}
    .company-name{font-size:25px;font-weight:850;color:var(--ink);letter-spacing:-.025em;margin:0}
    .company-role{font-size:14px;font-weight:850;color:var(--green);text-transform:uppercase;letter-spacing:.06em;text-align:right;min-width:230px}
    .company-desc{font-size:15px;color:var(--muted);margin-bottom:18px}
    .cols{display:grid;grid-template-columns:1fr 1fr;gap:24px}
    .mini-title{font-size:14px;text-transform:uppercase;letter-spacing:.09em;color:var(--gold);font-weight:850;margin:0 0 10px}
    .note{background:#f9fbfd;border:1px solid var(--line);border-left:5px solid var(--gold);border-radius:16px;padding:18px;color:#3d4a60;font-weight:650}
    .quote{background:linear-gradient(135deg,#244f37 0%,#3f7a54 100%);color:#fff;border-radius:24px;padding:28px;margin-top:20px}
    .quote p{color:#fff;font-size:20px;line-height:1.45;margin:0}
    .matrix{width:100%;border-collapse:separate;border-spacing:0;border:1px solid var(--line);border-radius:18px;overflow:hidden;background:#fff}
    .matrix th{background:var(--green);color:#fff;text-align:left;font-size:13px;text-transform:uppercase;letter-spacing:.07em;padding:14px}
    .matrix td{padding:14px;border-top:1px solid var(--line);vertical-align:top;color:#4a5667;font-size:15px}
    .matrix tr:nth-child(even) td{background:var(--soft2)}
    .footer{padding:24px 48px;background:#f7faf6;border-top:1px solid var(--line);font-size:13px;color:var(--muted);text-align:center}
    @media(max-width:900px){
      header,main{padding-left:26px;padding-right:26px}
      h1{font-size:42px}.position{font-size:18px}
      .grid-2,.grid-3,.result-grid,.steps,.cols{grid-template-columns:1fr}
      .owner-list{columns:1}
      .company-top{display:block}.company-role{text-align:left;margin-top:8px}
      .matrix{font-size:14px}
    }
    @media print{
      body{background:#fff}.page{width:100%;margin:0;border:none;border-radius:0;box-shadow:none}section{break-inside:avoid}.company{break-inside:avoid}.footer{display:none}
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="topbar"></div>
    <header>
      <div class="kicker">Презентация для производства продуктов питания</div>
      <h1>Елена Уткина</h1>
      <p class="position">Удаленный финансовый директор | Управленческая отчетность, себестоимость и бюджетирование в 1С УНФ</p>
      <p class="subtitle">Помогаю производственным компаниям видеть реальную прибыль, управлять валовой маржей, контролировать план-факт и получать отчетность без ручной сборки данных.</p>
      <div class="contacts">
        <div class="contact">+7 (912) 987-56-10</div>
        <div class="contact"><a href="mailto:elenasmart@yandex.ru">elenasmart@yandex.ru</a></div>
        <div class="contact"><a href="https://t.me/elena_utkina_fin">t.me/elena_utkina_fin</a></div>
      </div>
    </header>

    <main>
      <section>
        <div class="section-head"><div><div class="label">Почему я релевантна</div><h2>Я уже решала похожую задачу в производстве продуктов питания</h2></div></div>
        <p class="lead">У меня был проект в производственной компании из пищевой отрасли: как финансовый директор я занималась планированием, план-факт анализом, выстраивала управленческую отчетность в 1С УНФ, в том числе блок себестоимости.</p>
        <div class="result-grid" style="margin-top:22px;">
          <div class="result"><strong>+18%</strong><span>Рост чистой прибыли до налогов за 2025 год в пищевом производстве.</span></div>
          <div class="result"><strong>1С УНФ</strong><span>Управленческая отчетность, себестоимость и аналитика были выстроены в базе учета.</span></div>
          <div class="result"><strong>план-факт</strong><span>Ежемесячный контроль исполнения бюджета и причин отклонений.</span></div>
          <div class="result"><strong>маржа</strong><span>Контроль валовой маржи и факторов, влияющих на прибыльность продукции.</span></div>
        </div>
        <div class="quote"><p>Мой фокус — не просто «сделать отчеты», а выстроить систему, в которой команда ежемесячно понимает: где заработали, где потеряли, что изменилось к плану и какие решения нужны сейчас.</p></div>
      </section>

      <section>
        <div class="section-head"><div><div class="label">Запрос клиента</div><h2>Что именно я могу закрыть в вашей задаче</h2></div></div>
        <table class="matrix">
          <thead><tr><th>Что нужно компании</th><th>Что я сделаю</th><th>Управленческий результат</th></tr></thead>
          <tbody>
            <tr><td>Привести отчетность к среднеотраслевой логике и сделать ее читаемой</td><td>Настрою структуру управленческих отчетов: ОПиУ, ДДС факт-прогноз, Баланс, валовая маржа, план-факт, аналитика по продуктам/направлениям.</td><td>Собственник и команда будут видеть сопоставимые показатели и быстрее находить отклонения.</td></tr>
            <tr><td>Выстроить управленческую отчетность в базе учета</td><td>Участвую в настройке 1С УНФ, формирую требования к аналитикам, статьям, справочникам, правилам отражения операций и отчетам.</td><td>Отчеты формируются из учетной системы, а не собираются вручную из разрозненных таблиц.</td></tr>
            <tr><td>Сформировать автоматический отчет по себестоимости</td><td>Проверю логику состава затрат, распределения, выпуска, списания сырья, незавершенного производства и управленческой себестоимости.</td><td>Компания понимает реальную прибыльность продукции и может управлять ценами, рецептурами, закупками и ассортиментом.</td></tr>
            <tr><td>Собирать бюджет на месяц и год вместе с командой</td><td>Построю бюджетный процесс: продажи, производство, закупки, ФОТ, постоянные расходы, инвестиции, движение денег.</td><td>Появляется единый финансовый план, а не набор несвязанных ожиданий отделов.</td></tr>
            <tr><td>Ежемесячно анализировать валовую маржу, план-факт и прогноз</td><td>Настрою регулярный управленческий цикл: закрытие месяца, план-факт, факторный анализ маржи, прогноз до конца месяца/года.</td><td>Отклонения становятся управляемыми: понятно, что произошло и кто должен принять решение.</td></tr>
            <tr><td>Сигнализировать о рисках, потерях и тонких местах</td><td>Сформирую систему контрольных точек: маржинальность, себестоимость, остатки, ДЗ/КЗ, кассовые разрывы, отклонения расходов, убыточные продукты.</td><td>Риски видны заранее, а не после закрытия периода, когда деньги уже потеряны.</td></tr>
            <tr><td>Обновлять финансовую модель по потребности</td><td>Поддерживаю модель под сценарии: рост продаж, изменение цен, закупочных цен, ФОТ, производственной загрузки, инвестиций и налоговой нагрузки.</td><td>Решения по развитию проверяются на деньгах и прибыли до запуска.</td></tr>
          </tbody>
        </table>
      </section>

      <section>
        <div class="section-head"><div><div class="label">Финансовая архитектура</div><h2>Какие отчеты вы получите</h2></div></div>
        <div class="grid-3">
          <div class="card accent-card"><h3>ОПиУ / P&L</h3><p>Выручка, себестоимость, валовая прибыль, коммерческие и управленческие расходы, EBITDA/операционная прибыль, чистая прибыль до налогов.</p></div>
          <div class="card accent-card"><h3>ДДС факт-прогноз</h3><p>Фактические поступления и платежи, прогноз до конца месяца, платежный календарь, контроль кассовых разрывов.</p></div>
          <div class="card accent-card"><h3>Баланс</h3><p>Деньги, запасы, дебиторская и кредиторская задолженность, обязательства, капитал, связка прибыли и движения денег.</p></div>
          <div class="card"><h3>Себестоимость</h3><p>Сырье, упаковка, производственные затраты, выпуск, распределение расходов, маржинальность по продукции.</p></div>
          <div class="card"><h3>Бюджет</h3><p>Годовой и месячный бюджет, план продаж, закупок, производства, расходов и денежных потоков.</p></div>
          <div class="card"><h3>Риски и отклонения</h3><p>Сигналы по падению маржи, росту себестоимости, разрывам ликвидности, зависшим остаткам, ДЗ/КЗ и неэффективным расходам.</p></div>
        </div>
      </section>

      <section>
        <div class="section-head"><div><div class="label">Как будет выглядеть работа</div><h2>Первые 90 дней: от диагностики до регулярного управления</h2></div></div>
        <div class="steps">
          <div class="step" data-num="01"><h3>Диагностика учета</h3><p>Проверяю 1С УНФ, аналитику, справочники, статьи, качество данных, логику себестоимости и закрытия месяца.</p></div>
          <div class="step" data-num="02"><h3>Целевая модель отчетности</h3><p>Формирую структуру ОПиУ, ДДС, Баланса, бюджета, маржинальности и управленческих аналитик.</p></div>
          <div class="step" data-num="03"><h3>Настройка с командой</h3><p>Участвую в настройке базы, ставлю задачи 1С-специалисту, согласую правила учета и формат отчетов.</p></div>
          <div class="step" data-num="04"><h3>Регулярный цикл</h3><p>Запускаю ежемесячный бюджет, план-факт, прогноз, анализ рисков и управленческие выводы для команды.</p></div>
        </div>
        <div class="note" style="margin-top:20px;">Результат первых 90 дней — не разовая таблица, а работающий контур управления: план → факт → отклонения → прогноз → решения.</div>
      </section>

      <section>
        <div class="section-head"><div><div class="label">Себестоимость</div><h2>Особое внимание — валовой марже и производственной себестоимости</h2></div></div>
        <p class="lead">Для пищевого производства себестоимость — один из главных источников управленческих решений. Ошибка в сырье, упаковке, выпуске, списаниях или распределении затрат искажает прибыльность продукта и может привести к неверным ценовым решениям.</p>
        <div class="grid-2" style="margin-top:20px;">
          <div class="card accent-card">
            <h3>Что проверяю</h3>
            <ul>
              <li>структуру номенклатуры, рецептур и выпусков;</li>
              <li>правила списания сырья и упаковки;</li>
              <li>учет производственных затрат;</li>
              <li>распределение косвенных расходов;</li>
              <li>корректность закрытия месяца;</li>
              <li>маржинальность по продуктам и группам.</li>
            </ul>
          </div>
          <div class="card accent-card">
            <h3>Что получает команда</h3>
            <ul>
              <li>понятную себестоимость продукции;</li>
              <li>контроль валовой маржи ежемесячно;</li>
              <li>видимость убыточных и низкомаржинальных позиций;</li>
              <li>связку себестоимости с ценой и ассортиментом;</li>
              <li>обоснование решений по закупкам, производству и продажам.</li>
            </ul>
          </div>
        </div>
      </section>

      <section>
        <div class="section-head"><div><div class="label">Мой подход</div><h2>Я работаю как финансовый партнер, а не как внешний составитель отчетов</h2></div></div>
        <ul class="owner-list">
          <li>Разговариваю с собственником и командой на языке управленческих решений.</li>
          <li>Собираю финансовую картину из учета, а не создаю параллельную ручную систему.</li>
          <li>Не ограничиваюсь отчетами: показываю причины отклонений и финансовые последствия.</li>
          <li>Умею работать на стыке финансов, производства, продаж, закупок и 1С.</li>
          <li>Перевожу задачи собственника в ТЗ для учета, отчетности и автоматизации.</li>
          <li>Поддерживаю регулярный ритм управления: бюджет, факт, прогноз, риски, решения.</li>
        </ul>
      </section>

      <section>
        <div class="section-head"><div><div class="label">Ключевые компетенции</div><h2>Что будет полезно именно вашему производству</h2></div></div>
        <div class="tags">
          <span class="tag hot">1С УНФ</span><span class="tag hot">себестоимость</span><span class="tag hot">валовая маржа</span><span class="tag hot">план-факт</span><span class="tag">ОПиУ</span><span class="tag">ДДС факт-прогноз</span><span class="tag">Баланс</span><span class="tag">бюджетирование</span><span class="tag">финансовая модель</span><span class="tag">платежный календарь</span><span class="tag">производственный учет</span><span class="tag">контроль рисков</span><span class="tag">управление прибылью</span><span class="tag">KPI</span><span class="tag">автоматизация отчетности</span><span class="tag">AI-инструменты</span>
        </div>
      </section>

      <section>
        <div class="section-head"><div><div class="label">Опыт</div><h2>База финансового директора</h2></div></div>
        <div class="company">
          <div class="company-top"><h3 class="company-name">Производство продуктов питания</h3><div class="company-role">Финансовый директор проекта</div></div>
          <p class="company-desc">Проект по выстраиванию управленческой отчетности, планирования, план-факт анализа и блока себестоимости в 1С УНФ.</p>
          <div class="cols">
            <div><div class="mini-title">Что было сделано</div><ul><li>Выстроена управленческая отчетность в 1С УНФ.</li><li>Настроен управленческий контур по себестоимости.</li><li>Организовано финансовое планирование.</li><li>Запущен регулярный план-факт анализ.</li><li>Сформирована база для управленческих решений по прибыли и марже.</li></ul></div>
            <div><div class="mini-title">Результат</div><ul><li>Чистая прибыль до налогов за 2025 год увеличена на 18%.</li><li>Команда получила прозрачность по финансовому результату.</li><li>Управление стало опираться на данные учета и регулярный анализ отклонений.</li></ul></div>
          </div>
        </div>
        <div class="company">
          <div class="company-top"><h3 class="company-name">УралИнвест</h3><div class="company-role">Финансовый директор группы компаний</div></div>
